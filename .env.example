# WebScrape API 配置

# 基础配置
DEBUG=false

# API密钥（生产环境请修改）
MASTER_API_KEY=sk_demo_key_please_change_in_production

# ==================== 支付宝配置 ====================
# 沙箱环境配置（测试用）
ALIPAY_APP_ID=9021000162659359
ALIPAY_PRIVATE_KEY=你的应用私钥
ALIPAY_ALIPAY_PUBLIC_KEY=你的支付宝公钥
ALIPAY_NOTIFY_URL=https://your-domain.com/api/pay/notify
ALIPAY_SANDBOX=true

# 正式环境配置（沙箱审核通过后切换）
# ALIPAY_APP_ID=正式环境的AppID
# ALIPAY_PRIVATE_KEY=正式环境应用私钥
# ALIPAY_ALIPAY_PUBLIC_KEY=正式环境支付宝公钥
# ALIPAY_NOTIFY_URL=https://your-domain.com/api/pay/notify
# ALIPAY_SANDBOX=false
